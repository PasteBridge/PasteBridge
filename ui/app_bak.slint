import { ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "PasteBridge";
    width: 280px;
    height: 396px;
    no-frame: true;
    always-on-top: true;
    background: rgba(0, 0, 0, 0.84);
    

    callback minimize-window();
    callback hide-window();
    callback start-drag();
    callback new-clipboard-entry(text: string);

    in property <[string]> clipboard-history;
    in property <string> placeholder-text;
    // in property <[string]> clipboard-history: [
    //     "Mock 1: Hello World",
    //     "Mock 2: Rust + Slint",
    //     "Mock 3: 测试中文",
    //     "Mock 1: Hello World",
    //     "Mock 2: Rust + Slint",
    //     "Mock 3: 测试中文",
    //     "Mock 1: Hello World",
    //     "Mock 2: Rust + Slint",
    //     "Mock 3: 测试中文",
    //     "Mock 1: Hello World",
    //     "Mock 2: Rust + Slint",
    //     "Mock 3: 测试中文",
    // ];

    // White border and shadow container
    // Moved background to window base to reduce overdraw memory overhead
    Rectangle {
        border-width: 1px;
        border-color: rgba(255, 255, 255, 0.1);
    }

    // Background gradient layer
    Rectangle {
        background: @linear-gradient(122deg,rgba(30, 142, 212, 0) 0%, rgba(30, 142, 212, 0.1) 40%, rgba(143, 87, 199, 0.12) 75%, rgba(255, 201, 255, 0.18) 100%);
    }


    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        VerticalLayout {
            padding: 0px;
            spacing: 0px;

            // Clipboard history list
            ScrollView {
                vertical-stretch: 1;
                viewport-y: 0px; // For enabling animated smooth scrolling
                horizontal-scrollbar-policy: always-off;
                vertical-scrollbar-policy: always-off;

                VerticalLayout {
                    padding-left: 0px;
                    padding-right: 0px;
                    padding-top: 13px;
                    padding-bottom: 15px;
                    spacing: 8px;
                    alignment: start;

                    // 占位文本 - 列表为空时显示
                    if (root.clipboard-history.length == 0): Rectangle {
                        height: 120px;
                        background: transparent;

                        VerticalLayout {
                            spacing: 8px;
                            padding-top: 20px;
                            padding-bottom: 20px;
                            padding-left: 20px;
                            padding-right: 12px;
                            Text {
                                text: "你好";
                                color: #ffffffce;
                                font-size: 28px;
                                font-weight: 300;
                                horizontal-alignment: left;
                            }

                            Text {
                                text: "你的剪贴板历史将显示在这里";
                                color: rgba(255, 255, 255, 0.67);
                                font-size: 12px;
                                horizontal-alignment: left;
                            }

                            Text {
                                text: "";
                                color: rgba(255, 255, 255, 0.5);
                                font-size: 11px;
                                horizontal-alignment: left;
                            }
                        }
                    }

                    for item[index] in root.clipboard-history: Rectangle {
                        height: 52px;
                        background: rgba(61, 61, 61, 0.4);
                        border-radius: 0px;
                        border-width: 0px;
                        border-color: rgba(255, 255, 255, 0.1);
                        // drop-shadow is disabled for performance
                        // drop-shadow-color: rgba(0, 0, 0, 0.5);
                        // drop-shadow-offset-y: 2px;
                        // drop-shadow-blur: 4px;

                        // Animation disabled for performance
                        // animate background { duration: 100ms; easing: ease-in; }

                        ta := TouchArea { }

                        states [
                            hovered when ta.has-hover: {
                                background: rgba(90, 90, 90, 0.6);
                            }
                        ]

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            padding-top: 8px;
                            padding-bottom: 8px;

                            Text {
                                text: item;
                                color: #ffffff;
                                font-size: 12px;
                                vertical-alignment: center;
                                overflow: elide;
                                vertical-stretch: 0;
                                horizontal-stretch: 0;
                            }
                        }
                    }
                }
            }

            Rectangle {
                // Remove expensive shadow, replace with a subtle gradient effect for performance
                height: 1px;
                background: #4d4d4d;
            }
            Rectangle {
                height: 5px;
                background: @linear-gradient(180deg, rgba(0, 0, 0, 0.5) 0%, rgba(0, 0, 0, 0) 100%);
            }

            // Bottom bar - Search box
            Rectangle {
                height: 40px;
                background: rgba(0, 0, 0, 0.1);

                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 8px;

                    Text {
                        text: "搜索...";
                        color: rgba(255, 255, 255, 0.5);
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Vertical line on toolbar left
        Rectangle {
            width: 1px;
            background: rgba(255, 255, 255, 0.1);
        }

        // Right toolbar (44px wide) - 拖动区域
        Rectangle {
            width: 44px;
            background: rgba(0, 0, 0, 0.3);

            TouchArea {
                width: 100%;
                height: 100%;
                pointer-event(ev) => {
                    if (ev.button == PointerEventButton.left && ev.kind == PointerEventKind.down) {
                        root.start-drag();
                    }
                }

                VerticalLayout {
                padding-left: 10.5px;
                padding-right: 10.5px;
                padding-top: 13px;
                padding-bottom: 12px;
                spacing: 12px;

                Image {
                    source: @image-url("favicon.png");
                    width: 26px;
                    height: 26px;
                }

                Image {
                    source: @image-url("pin.png");
                    width: 16px;
                    height: 16px;
                }

                Rectangle {
                    width: 24px;
                    height: 24px;
                    background: #555555;
                    border-radius: 4px;

                    Text {
                        text: "❤";
                        color: #ffffff;
                        font-size: 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        width: 100%;
                        height: 100%;
                        clicked => {
                            root.minimize-window();
                        }
                    }
                }

                Rectangle {
                    width: 24px;
                    height: 24px;
                    background: #e81123;
                    border-radius: 4px;

                    Text {
                        text: "X";
                        color: #ffffff;
                        font-size: 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        width: 100%;
                        height: 100%;
                        clicked => {
                            root.hide-window();
                        }
                    }
                }
            }
            }
        }
    }
}


