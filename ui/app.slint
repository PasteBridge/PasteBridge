import { ScrollView } from "std-widgets.slint";

export component AppWindow inherits Window {
    title: "PasteBridge";
    width: 280px;
    height: 396px;
    no-frame: true;
    always-on-top: true;
    background:transparent;
    

    callback minimize-window();
    callback hide-window();
    callback start-drag();
    callback new-clipboard-entry(text: string);
    callback copy-item(text: string);
    callback clear-history();
    callback show-tooltip(text: string, x: float, y: float);
    callback hide-tooltip();

    in property <[string]> clipboard-history;
    
    // Tooltip hover detection
    property <bool> item-hovered: false;
    property <string> hovered-item-text: "";
    property <length> hovered-item-x: 0;
    property <length> hovered-item-y: 0;
    in property <string> placeholder-text;

    // Copied 弹出提示
    popup := PopupWindow {
        x: 0px;
        y: -48px;
        width: 80px;
        height: 32px;

        Rectangle {
            background: #1a1a1a;
            border-radius: 6px;

            Text {
                text: "Copied";
                color: #ffffff;
                font-size: 13px;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }
    }
    
    // Hover detection timer - poll every 100ms
    property <bool> timer-active: true;
    Timer {
        interval: 100ms;
        running: timer-active;
        triggered => {
            // Will be updated by list items
        }
    }
    
    // in property <[string]> clipboard-history: [
    //     "Mock 1: Hello World",
    //     "Mock 2: Rust + Slint",
    //     "Mock 3: 测试中文",
    //     "Mock 1: Hello World",
    //     "Mock 2: Rust + Slint",
    //     "Mock 3: 测试中文",
    //     "Mock 1: Hello World",
    //     "Mock 2: Rust + Slint",
    //     "Mock 3: 测试中文",
    //     "Mock 1: Hello World",
    //     "Mock 2: Rust + Slint",
    //     "Mock 3: 测试中文",
    // ];

    // White border and shadow container
    Rectangle {
        background: rgba(0, 0, 0, 0.84);
        border-width: 1px;
        border-color: rgba(255, 255, 255, 0.1);
    }

    // Background gradient layer
    Rectangle {
        background: @linear-gradient(122deg,rgba(30, 142, 212, 0) 0%, rgba(30, 142, 212, 0.1) 40%, rgba(143, 87, 199, 0.12) 75%, rgba(255, 201, 255, 0.18) 100%);
    }


    HorizontalLayout {
        padding: 0px;
        spacing: 0px;

        //Main content area
        VerticalLayout {
            padding: 0px;
            spacing: 0px;

            // Clipboard history list
            ScrollView {
                vertical-stretch: 1;
                viewport-y: 0px; // For enabling animated smooth scrolling
                horizontal-scrollbar-policy: always-off;
                vertical-scrollbar-policy: always-off;

                VerticalLayout {
                    padding-left: 0px;
                    padding-right: 0px;
                    padding-top: 13px;
                    padding-bottom: 15px;
                    spacing: 8px;
                    alignment: start;

                    // 占位文本 - 列表为空时显示
                    if (root.clipboard-history.length == 0): Rectangle {
                        height: 120px;
                        background: transparent;

                        VerticalLayout {
                            spacing: 8px;
                            padding-top: 20px;
                            padding-bottom: 20px;
                            padding-left: 20px;
                            padding-right: 12px;
                            Text {
                                text: "你好";
                                color: #ffffffce;
                                font-size: 28px;
                                font-weight: 300;
                                horizontal-alignment: left;
                            }

                            Text {
                                text: "你的剪贴板历史将显示在这里";
                                color: rgba(255, 255, 255, 0.67);
                                font-size: 12px;
                                horizontal-alignment: left;
                            }

                            Text {
                                text: "";
                                color: rgba(255, 255, 255, 0.5);
                                font-size: 11px;
                                horizontal-alignment: left;
                            }
                        }
                    }

                    for item[index] in root.clipboard-history: Rectangle {
                        height: 52px;
                        background: rgba(61, 61, 61, 0.4);
                        border-radius: 0px;
                        border-width: 0px;
                        border-color: rgba(255, 255, 255, 0.1);
                        drop-shadow-color: rgba(0, 0, 0, 0.5);
                        drop-shadow-offset-y: 2px;
                        drop-shadow-blur: 4px;

                        animate background { duration: 100ms; easing: ease-in; }

                        ta := TouchArea {
                            clicked => {
                                root.copy-item(item);
                                popup.show();
                                if (true) {
                                    popup.close();
                                }
                            }
                        }

                        states [
                            hovered when ta.has-hover: {
                                background: rgba(90, 90, 90, 0.6);
                            }
                        ]

                        HorizontalLayout {
                            padding-left: 12px;
                            padding-right: 12px;
                            padding-top: 8px;
                            padding-bottom: 8px;

                            Text {
                                text: item;
                                color: #ffffff;
                                font-size: 12px;
                                vertical-alignment: top;
                                overflow: clip;
                                vertical-stretch: 0;
                                horizontal-stretch: 0;
                            }
                        }
                    }
                }
            }

            //分割条
            Rectangle {
                drop-shadow-color: rgb(0, 0, 0);
                drop-shadow-offset-y: 5px;
                drop-shadow-blur: 10px;
                height: 1px;
                background: #4d4d4d;
            }

            // Bottom bar - Search box
            Rectangle {
                drop-shadow-color: rgba(0, 0, 0, 0.3);
                drop-shadow-offset-y: -10px;
                drop-shadow-blur: 20px;
                height: 40px;
                background: rgba(0, 0, 0, 0.1);

                HorizontalLayout {
                    padding-left: 12px;
                    padding-right: 12px;
                    spacing: 8px;

                    Text {
                        text: "搜索...";
                        color: rgba(255, 255, 255, 0.5);
                        font-size: 12px;
                        vertical-alignment: center;
                    }
                }
            }
        }

        // Vertical line on toolbar left
        Rectangle {
            width: 1px;
            background: rgba(255, 255, 255, 0.1);
        }

        // Right toolbar (44px wide) - 拖动区域
        Rectangle {
            width: 44px;
            background: rgba(0, 0, 0, 0.3);

            TouchArea {
                width: 100%;
                height: 100%;
                pointer-event(ev) => {
                    if (ev.button == PointerEventButton.left && ev.kind == PointerEventKind.down) {
                        root.start-drag();
                    }
                }

                VerticalLayout {
                padding-left: 10.5px;
                padding-right: 10.5px;
                padding-top: 13px;
                padding-bottom: 12px;
                spacing: 12px;

                Image {
                    source: @image-url("favicon.png");
                    width: 26px;
                    height: 26px;
                }

                Image {
                    source: @image-url("pin.png");
                    width: 16px;
                    height: 16px;
                }

                Rectangle {
                    width: 24px;
                    height: 24px;
                    background: transparent;
                }

                // Clear button
                Rectangle {
                    width: 24px;
                    height: 24px;
                    background: #555555;
                    border-radius: 4px;

                    Text {
                        text: "🗑";
                        color: #ffffff;
                        font-size: 12px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        width: 100%;
                        height: 100%;
                        clicked => {
                            root.clear-history();
                        }
                    }
                }

                Rectangle {
                    width: 24px;
                    height: 24px;
                    background: #555555;
                    border-radius: 4px;

                    Text {
                        text: "❤";
                        color: #ffffff;
                        font-size: 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        width: 100%;
                        height: 100%;
                        clicked => {
                            root.minimize-window();
                        }
                    }
                }

                Rectangle {
                    width: 24px;
                    height: 24px;
                    background: #e81123;
                    border-radius: 4px;

                    Text {
                        text: "X";
                        color: #ffffff;
                        font-size: 14px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                    }

                    TouchArea {
                        width: 100%;
                        height: 100%;
                        clicked => {
                            root.hide-window();
                        }
                    }
                }
            }
            }
        }
    }
}


